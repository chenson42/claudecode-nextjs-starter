# --- Database --------------------------------------------------------------
# Neon Postgres pooled connection string (works fine in serverless functions)
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# --- NextAuth (v5 / Auth.js) ------------------------------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Public origin of the deployed app. Local dev defaults to http://localhost:3000.
# NextAuth v5 uses AUTH_URL (not the v4 NEXTAUTH_URL).
AUTH_URL=http://localhost:3000

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- First-run admin bootstrap ---------------------------------------------
# Comma-separated list of email addresses that should be granted the `admin`
# role automatically when they first sign in via Google. Single value or many.
# Examples:
#   INITIAL_ADMIN_EMAILS=you@example.com
#   INITIAL_ADMIN_EMAILS=you@example.com,teammate@example.com
INITIAL_ADMIN_EMAILS=you@example.com

# --- Seeded local admin (for credentials-login testing) --------------------
# If both are set, `npm run db:seed` upserts a credentials-login admin user
# with this email + password and binds them to the admin role. twoFactorRequired
# is false on this user so /admin loads in one click — convenient for local
# testing, NOT suitable for production. Leave both empty in any deployed env.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- TOTP 2FA --------------------------------------------------------------
# 32-byte base64 key used to AES-256-GCM-encrypt every enrolled TOTP secret
# at rest. Rotating this key invalidates every enrolled 2FA secret in the DB —
# do not rotate casually.
# Generate: openssl rand -base64 32
AUTH_TOTP_ENCRYPTION_KEY=

# --- App URL ---------------------------------------------------------------
# Public URL of the deployed app, used to generate email verification links.
# Must be set in production. Local dev falls back to http://localhost:3000.
# Example: https://myapp.vercel.app
NEXT_PUBLIC_APP_URL=

# --- Email (Resend) --------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="Claude Code Starter <noreply@example.com>"

# --- Rate limiting (Upstash Redis) — Optional ------------------------------
# When both vars are set the rate limiter upgrades from in-memory (resets on
# cold start, single-instance only) to Upstash Redis (durable, distributed).
# Recommended for any production deployment. https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Escape hatch — short-circuits every checkRateLimit() to "allowed". Set this
# in local .env.local when iterating on e2e tests so repeated signin attempts
# don't accumulate state in the dev server's in-memory limiter. NEVER set in
# production — defeats the whole point.
# RATE_LIMIT_DISABLED=true
