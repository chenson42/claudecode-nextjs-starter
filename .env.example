# Neon Postgres (pooled connection string)
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Seeds the first admin user by email at signup
INITIAL_ADMIN_EMAILS=you@example.com

# AES-256-GCM key for encrypting TOTP secrets at rest (base64, 32 bytes)
# generate: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=

# Resend (transactional email)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="Claude Code Starter <noreply@example.com>"
